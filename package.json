{
    "name": "met-formio",
    "version": "2.0.0-rc1",
    "private": false,
    "description": "React Formio Components for the Modern Engagement Tools project.",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/bcgov/met-formio.git"
    },
    "main": "lib/index.js",
    "module": "node",
    "scripts": {
        "test:coverage": "nyc --reporter=text mocha --reporter spec './{,!(node_modules)/**/}*.spec.js'",
        "test": "mocha --require ts-node/register --reporter spec './{,!(node_modules)/**/}*.spec.ts'",
        "watch": "tsc -w",
        "webpack:dev": "webpack",
        "webpack:prod": "webpack --config webpack.prod.js",
        "webpack:use": "webpack --config webpack.use.js",
        "webpack": "npm run webpack:dev && npm run webpack:prod && npm run webpack:use",
        "build": "tsc && gulp templates && npm run webpack && sass ./src/sass/contrib.scss ./dist/met-formio-components.css",
        "clean": "rm -rf coverage dist lib",
        "purge": "rm -rf node_modules",
        "lint": "eslint src --ext .ts"
    },
    "files": [
        "dist",
        "lib"
    ],
    "keywords": [
        "Form.io",
        "components"
    ],
    "dependencies": {
        "@formio/js": "^5.3.0",
        "lodash": "^4.17.21",
        "native-promise-only": "^0.8.1"
    },
    "devDependencies": {
        "@types/chai": "^4.2.22",
        "@types/ejs": "^3.1.0",
        "@types/mocha": "^9.0.0",
        "@types/node": "^24.12.0",
        "@types/sinon": "^10.0.6",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "chai": "^4.3.4",
        "eslint": "^8.57.0",
        "gulp": "^4.0.2",
        "gulp-insert": "^0.5.0",
        "gulp-rename": "^2.0.0",
        "gulp-template": "^5.0.0",
        "mocha": "^9.1.3",
        "nyc": "^15.0.1",
        "pre-commit": "^1.2.2",
        "sass": "^1.77",
        "sinon": "^12.0.1",
        "ts-node": "^10.4.0",
        "ts-sinon": "^2.0.2",
        "typescript": "^5.4.0",
        "webpack": "^5.64.1",
        "webpack-cli": "^4.9.1"
    }
}
